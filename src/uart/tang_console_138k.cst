// ============================================================
// Tang Console 138K ピン制約: UART TX + CFG LED
// ============================================================
// UART: BL616 USB-UART ブリッジ経由 (USB-C デバッグポート)
// LED: ステータス LED (RGB LED1)
// ============================================================

// UART TX (U15, Bank 5) — BL616 USB-UART → PC
IO_LOC  "uart_tx" U15;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33 DRIVE=8;

// READY LED (U12, Bank 10) — LED1 Red
IO_LOC  "led_ready" U12;
IO_PORT "led_ready" IO_TYPE=LVCMOS33 DRIVE=8;

// DONE LED (G11, Bank 10) — LED1 Blue
IO_LOC  "led_done" G11;
IO_PORT "led_done" IO_TYPE=LVCMOS33 DRIVE=8;
