// ============================================================
// Tang Console 138K ピン制約: HDMI TMDS 出力 (PG484フォールバック用ダミーマッピング)
// ============================================================
// ターゲット: GW5AST-LV138PG484AC1/I0 (Bank 3)
// ============================================================

// システムクロック (50MHz, Bank 5)
IO_LOC  "clk_50m" V10;
IO_PORT "clk_50m" IO_TYPE=LVCMOS33;

// HDMI Data Channel 2 (Red)
IO_LOC  "tmds_d2_p" L19;
IO_PORT "tmds_d2_p" IO_TYPE=LVDS25;

// HDMI Data Channel 1 (Green)
IO_LOC  "tmds_d1_p" N20;
IO_PORT "tmds_d1_p" IO_TYPE=LVDS25;

// HDMI Data Channel 0 (Blue + HSYNC/VSYNC)
IO_LOC  "tmds_d0_p" K17;
IO_PORT "tmds_d0_p" IO_TYPE=LVDS25;

// HDMI Clock Channel
IO_LOC  "tmds_clk_p" K18;
IO_PORT "tmds_clk_p" IO_TYPE=LVDS25;

// ステータス LED (Bank 10)
IO_LOC  "led" U12;
IO_PORT "led" IO_TYPE=LVCMOS33 DRIVE=8;
